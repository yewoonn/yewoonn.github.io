# Copy this file to `.env.local` and fill in the values, then restart `npm run dev`.
# Get these from: Firebase Console → Project settings → General → "Your apps" → SDK setup (Config).
# NOTE: These Firebase values are public by design (they ship in the client bundle).
#       Your data is protected by Firestore Security Rules, not by hiding these.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Secret path to the private analytics page: the site opens it at  /#<this value>
# Change this to your own hard-to-guess string.
VITE_ADMIN_SLUG=admin-b15baa82ee
